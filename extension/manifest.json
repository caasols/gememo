{
  "manifest_version": 3,
  "name": "Gememo",
  "version": "0.3.8",
  "description": "Bot-free AI meeting notes from Google Meet — saved to Craft, Obsidian, Bear or Apple Notes when you leave.",
  "permissions": [
    "nativeMessaging",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://meet.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["design_tokens.js", "constants.js", "content_meet.js"],
      "css": ["content_meet.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Gememo — AI Meeting Notes"
  },
  "commands": {
    "capture-now": {
      "suggested_key": { "default": "Ctrl+Shift+Y", "mac": "Command+Shift+Y" },
      "description": "Capture meeting notes now"
    }
  }
}
